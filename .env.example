# Supabase configuration — copy to `.env.local` and fill in.
# .env.local is gitignored; this template is committed for onboarding.

# Public, browser-exposed values (the publishable/anon key; read access is RLS-gated).
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-publishable-or-anon-key>

# SERVER-ONLY SECRET — required for POST /api/verify (writes bypass RLS).
# Never commit this. Supabase Dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
